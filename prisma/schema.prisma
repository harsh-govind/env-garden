generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum ProjectAccessScope {
  ALL_PROJECTS
  SELECTED_PROJECTS
}

enum EnvironmentAccessScope {
  ALL_ENVIRONMENTS
  SELECTED_ENVIRONMENTS
}

enum ProjectRole {
  OWNER
  CONTRIBUTOR
  VIEWER
}

enum WorkspaceInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model User {
  id                       String             @id @default(cuid())
  email                    String             @unique
  name                     String?
  emailVerified            DateTime?
  image                    String?
  avatar                   String             @default("sprout")
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  accounts                 Account[]
  sessions                 Session[]
  createdWorkspaces        Workspace[]        @relation("WorkspaceCreator")
  createdProjects          Project[]          @relation("ProjectCreator")
  createdEnvFiles          EnvFile[]          @relation("EnvFileCreator")
  workspaceMemberships     WorkspaceMember[]  @relation("WorkspaceMemberUser")
  workspaceMembers         WorkspaceMember[]  @relation("WorkspaceMemberAdder")
  projectMembers           ProjectMember[]    @relation("ProjectMemberAdder")
  envAccesses              ProjectEnvAccess[] @relation("ProjectEnvAccessGrantor")
  workspaceInvitesSent     WorkspaceInvite[]  @relation("WorkspaceInviteSender")
  workspaceInvitesAccepted WorkspaceInvite[]  @relation("WorkspaceInviteAccepter")
  workspaceInvitesRevoked  WorkspaceInvite[]  @relation("WorkspaceInviteRevoker")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Workspace {
  id          String             @id @default(cuid())
  name        String
  description String?
  createdById String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  createdBy   User               @relation("WorkspaceCreator", fields: [createdById], references: [id], onDelete: Restrict)
  projects    Project[]
  members     WorkspaceMember[]
  invites     WorkspaceInvite[]
  history     WorkspaceHistory[]

  @@index([createdById])
}

model Project {
  id             String                   @id @default(cuid())
  workspaceId    String
  name           String
  description    String?
  createdById    String
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  workspace      Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy      User                     @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  members        ProjectMember[]
  envFiles       EnvFile[]
  envAccesses    ProjectEnvAccess[]
  inviteAccesses WorkspaceInviteProject[]
  encryptionKey  ProjectEncryptionKey?

  @@unique([id, workspaceId])
  @@index([workspaceId])
  @@index([createdById])
}

model ProjectEncryptionKey {
  id           String   @id @default(cuid())
  projectId    String   @unique
  encryptedKey String
  iv           String
  authTag      String
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model WorkspaceMember {
  id                            String                 @id @default(cuid())
  workspaceId                   String
  userId                        String
  role                          WorkspaceRole          @default(MEMBER)
  projectAccessScope            ProjectAccessScope     @default(SELECTED_PROJECTS)
  defaultProjectRole            ProjectRole            @default(VIEWER)
  defaultEnvironmentAccessScope EnvironmentAccessScope @default(ALL_ENVIRONMENTS)
  addedById                     String?
  createdAt                     DateTime               @default(now())
  updatedAt                     DateTime               @updatedAt
  workspace                     Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user                          User                   @relation("WorkspaceMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  addedBy                       User?                  @relation("WorkspaceMemberAdder", fields: [addedById], references: [id], onDelete: SetNull)
  projectMembers                ProjectMember[]

  @@unique([workspaceId, userId])
  @@unique([id, workspaceId])
  @@index([workspaceId])
  @@index([userId])
  @@index([addedById])
}

model ProjectMember {
  id                     String                 @id @default(cuid())
  workspaceId            String
  projectId              String
  workspaceMemberId      String
  role                   ProjectRole            @default(CONTRIBUTOR)
  environmentAccessScope EnvironmentAccessScope @default(SELECTED_ENVIRONMENTS)
  addedById              String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  project                Project                @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  workspaceMember        WorkspaceMember        @relation(fields: [workspaceMemberId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  addedBy                User?                  @relation("ProjectMemberAdder", fields: [addedById], references: [id], onDelete: SetNull)
  envAccesses            ProjectEnvAccess[]

  @@unique([projectId, workspaceMemberId])
  @@unique([id, projectId])
  @@index([workspaceId])
  @@index([projectId])
  @@index([workspaceMemberId])
  @@index([addedById])
}

model WorkspaceInvite {
  id                            String                   @id @default(cuid())
  workspaceId                   String
  email                         String
  role                          WorkspaceRole            @default(MEMBER)
  projectAccessScope            ProjectAccessScope       @default(SELECTED_PROJECTS)
  defaultProjectRole            ProjectRole              @default(VIEWER)
  defaultEnvironmentAccessScope EnvironmentAccessScope   @default(ALL_ENVIRONMENTS)
  status                        WorkspaceInviteStatus    @default(PENDING)
  tokenHash                     String                   @unique
  invitedById                   String?
  acceptedById                  String?
  revokedById                   String?
  emailSentAt                   DateTime?
  expiresAt                     DateTime
  acceptedAt                    DateTime?
  revokedAt                     DateTime?
  createdAt                     DateTime                 @default(now())
  updatedAt                     DateTime                 @updatedAt
  workspace                     Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy                     User?                    @relation("WorkspaceInviteSender", fields: [invitedById], references: [id], onDelete: SetNull)
  acceptedBy                    User?                    @relation("WorkspaceInviteAccepter", fields: [acceptedById], references: [id], onDelete: SetNull)
  revokedBy                     User?                    @relation("WorkspaceInviteRevoker", fields: [revokedById], references: [id], onDelete: SetNull)
  projectAccesses               WorkspaceInviteProject[]

  @@unique([id, workspaceId])
  @@index([workspaceId])
  @@index([workspaceId, email])
  @@index([workspaceId, status])
  @@index([invitedById])
  @@index([acceptedById])
  @@index([revokedById])
}

model WorkspaceInviteProject {
  id                     String                       @id @default(cuid())
  workspaceInviteId      String
  workspaceId            String
  projectId              String
  role                   ProjectRole                  @default(VIEWER)
  environmentAccessScope EnvironmentAccessScope       @default(SELECTED_ENVIRONMENTS)
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  workspaceInvite        WorkspaceInvite              @relation(fields: [workspaceInviteId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  project                Project                      @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  environments           WorkspaceInviteEnvironment[]

  @@unique([workspaceInviteId, projectId])
  @@index([workspaceInviteId])
  @@index([workspaceId])
  @@index([projectId])
  @@index([projectId, workspaceId])
}

model WorkspaceInviteEnvironment {
  id                       String                 @id @default(cuid())
  workspaceInviteProjectId String
  environment              String
  createdAt                DateTime               @default(now())
  workspaceInviteProject   WorkspaceInviteProject @relation(fields: [workspaceInviteProjectId], references: [id], onDelete: Cascade)

  @@unique([workspaceInviteProjectId, environment])
  @@index([workspaceInviteProjectId])
}

model EnvFile {
  id          String        @id @default(cuid())
  workspaceId String
  projectId   String
  name        String
  environment String
  description String?
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  project     Project       @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  createdBy   User          @relation("EnvFileCreator", fields: [createdById], references: [id], onDelete: Restrict)
  variables   EnvVariable[]

  @@unique([projectId, name])
  @@index([workspaceId])
  @@index([projectId])
  @@index([projectId, environment])
  @@index([createdById])
}

model EnvVariable {
  id             String   @id @default(cuid())
  envFileId      String
  key            String
  encryptedValue String
  iv             String
  authTag        String
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  envFile        EnvFile  @relation(fields: [envFileId], references: [id], onDelete: Cascade)

  @@unique([envFileId, key])
  @@index([envFileId])
}

model ProjectEnvAccess {
  id              String        @id @default(cuid())
  workspaceId     String
  projectId       String
  projectMemberId String
  environment     String
  grantedById     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  project         Project       @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  projectMember   ProjectMember @relation(fields: [projectMemberId, projectId], references: [id, projectId], onDelete: Cascade)
  grantedBy       User?         @relation("ProjectEnvAccessGrantor", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([projectMemberId, environment])
  @@index([workspaceId])
  @@index([projectId])
  @@index([projectId, environment])
  @@index([projectMemberId])
  @@index([grantedById])
}

model WorkspaceHistory {
  id          String    @id @default(cuid())
  operation   String
  message     String    @default("")
  data        Json
  createdAt   DateTime  @default(now())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
}
