generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum ProjectAccessScope {
  ALL_PROJECTS
  SELECTED_PROJECTS
}

enum InviteEnvironmentScope {
  ALL_ENVIRONMENTS
  SELECTED_ENVIRONMENTS
}

enum ProjectRole {
  OWNER
  ADMIN
  CONTRIBUTOR
  VIEWER
}

model User {
  id                   String            @id @default(cuid())
  email                String            @unique
  name                 String?
  avatar               String            @default("sprout")
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  createdWorkspaces    Workspace[]       @relation("WorkspaceCreator")
  createdProjects      Project[]         @relation("ProjectCreator")
  createdEnvFiles      EnvFile[]         @relation("EnvFileCreator")
  workspaceMemberships WorkspaceMember[] @relation("WorkspaceMemberUser")
  workspaceMembers     WorkspaceMember[] @relation("WorkspaceMemberAdder")
  workspaceInvitesSent WorkspaceInvite[] @relation("WorkspaceInviteInviter")
  projectMembers       ProjectMember[]   @relation("ProjectMemberAdder")
  envAccesses          ProjectEnvAccess[] @relation("ProjectEnvAccessGrantor")
}

model Workspace {
  id          String             @id @default(cuid())
  name        String
  description String?
  createdById String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  createdBy   User               @relation("WorkspaceCreator", fields: [createdById], references: [id], onDelete: Restrict)
  projects    Project[]
  members     WorkspaceMember[]
  invites     WorkspaceInvite[]
  history     WorkspaceHistory[]

  @@index([createdById])
}

model Project {
  id          String          @id @default(cuid())
  workspaceId String
  name        String
  description String?
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy   User            @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  members     ProjectMember[]
  envFiles    EnvFile[]
  envAccesses ProjectEnvAccess[]
  inviteAccesses WorkspaceInviteProject[]
  encryptionKey ProjectEncryptionKey?

  @@unique([id, workspaceId])
  @@index([workspaceId])
  @@index([createdById])
}

model ProjectEncryptionKey {
  id           String   @id @default(cuid())
  projectId    String   @unique
  encryptedKey String
  iv           String
  authTag      String
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model WorkspaceMember {
  id                 String             @id @default(cuid())
  workspaceId        String
  userId             String
  role               WorkspaceRole      @default(MEMBER)
  projectAccessScope ProjectAccessScope @default(SELECTED_PROJECTS)
  addedById          String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  workspace          Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user               User               @relation("WorkspaceMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  addedBy            User?              @relation("WorkspaceMemberAdder", fields: [addedById], references: [id], onDelete: SetNull)
  projectMembers     ProjectMember[]

  @@unique([workspaceId, userId])
  @@unique([id, workspaceId])
  @@index([workspaceId])
  @@index([userId])
  @@index([addedById])
}

model WorkspaceInvite {
  id             String                   @id @default(cuid())
  workspaceId    String
  email          String
  role           WorkspaceRole            @default(MEMBER)
  tokenHash      String                   @unique
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  workspace      Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy      User                     @relation("WorkspaceInviteInviter", fields: [invitedById], references: [id], onDelete: Restrict)
  projectAccesses WorkspaceInviteProject[]

  @@index([workspaceId])
  @@index([email])
  @@index([invitedById])
  @@index([expiresAt])
}

model WorkspaceInviteProject {
  id                String                      @id @default(cuid())
  workspaceInviteId String
  workspaceId       String
  projectId         String
  environmentScope  InviteEnvironmentScope      @default(SELECTED_ENVIRONMENTS)
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  workspaceInvite   WorkspaceInvite             @relation(fields: [workspaceInviteId], references: [id], onDelete: Cascade)
  project           Project                     @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  environments      WorkspaceInviteEnvironment[]

  @@unique([workspaceInviteId, projectId])
  @@index([workspaceInviteId])
  @@index([workspaceId])
  @@index([projectId])
}

model WorkspaceInviteEnvironment {
  id                       String                 @id @default(cuid())
  workspaceInviteProjectId String
  environment              String
  createdAt                DateTime               @default(now())
  workspaceInviteProject   WorkspaceInviteProject @relation(fields: [workspaceInviteProjectId], references: [id], onDelete: Cascade)

  @@unique([workspaceInviteProjectId, environment])
  @@index([workspaceInviteProjectId])
}

model ProjectMember {
  id                String          @id @default(cuid())
  workspaceId       String
  projectId         String
  workspaceMemberId String
  role              ProjectRole     @default(CONTRIBUTOR)
  addedById         String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  project           Project         @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  workspaceMember   WorkspaceMember @relation(fields: [workspaceMemberId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  addedBy           User?           @relation("ProjectMemberAdder", fields: [addedById], references: [id], onDelete: SetNull)
  envAccesses       ProjectEnvAccess[]

  @@unique([projectId, workspaceMemberId])
  @@unique([id, projectId])
  @@index([workspaceId])
  @@index([projectId])
  @@index([workspaceMemberId])
  @@index([addedById])
}

model EnvFile {
  id          String            @id @default(cuid())
  workspaceId String
  projectId   String
  name        String
  environment String
  description String?
  createdById String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  project     Project           @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  createdBy   User              @relation("EnvFileCreator", fields: [createdById], references: [id], onDelete: Restrict)
  variables   EnvVariable[]

  @@unique([projectId, name])
  @@index([workspaceId])
  @@index([projectId])
  @@index([projectId, environment])
  @@index([createdById])
}

model EnvVariable {
  id             String   @id @default(cuid())
  envFileId      String
  key            String
  encryptedValue String
  iv             String
  authTag        String
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  envFile        EnvFile  @relation(fields: [envFileId], references: [id], onDelete: Cascade)

  @@unique([envFileId, key])
  @@index([envFileId])
}

model ProjectEnvAccess {
  id              String          @id @default(cuid())
  workspaceId     String
  projectId       String
  projectMemberId String
  environment     String
  grantedById     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  project         Project         @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  projectMember   ProjectMember   @relation(fields: [projectMemberId, projectId], references: [id, projectId], onDelete: Cascade)
  grantedBy       User?           @relation("ProjectEnvAccessGrantor", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([projectMemberId, environment])
  @@index([workspaceId])
  @@index([projectId])
  @@index([projectId, environment])
  @@index([projectMemberId])
  @@index([grantedById])
}

model WorkspaceHistory {
  id          String    @id @default(cuid())
  operation   String
  message     String    @default("")
  data        Json
  createdAt   DateTime  @default(now())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
}
